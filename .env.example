# HubSpot Private App token (Settings → Integrations → Private Apps)
HUBSPOT_ACCESS_TOKEN=your_private_app_token_here

# Anthropic — for AI narrative synthesis (optional; use --no-claude to skip)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Diagnostic tuning (optional — defaults shown)
STUCK_DEAL_DAYS=21          # flag deal as stuck after N days in same stage
NO_ACTIVITY_DAYS=14         # flag no engagement after N days
AVG_DEAL_VALUE=50000        # fallback if deal has no amount set in HubSpot
PIPELINE_ID=                # leave blank to scan all pipelines
OUTPUT_DIR=./reports        # where to write the markdown report
